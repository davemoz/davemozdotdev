{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "davemozdotdev",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "c00a9fa2497f6dd97d55b2ac173453d7",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "routes": [
    {
      "pattern": "davemoz.dev",
      "zone_name": "davemoz.dev",
      "custom_domain": true,
    },
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "davemozdotdev",
    },
  ],
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "davemozdotdev",
    },
  ],
  "images": {
    "binding": "IMAGES",
  },
  "observability": {
    "enabled": true,
  },
}
